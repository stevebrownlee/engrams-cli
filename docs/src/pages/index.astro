---
import "../styles/global.css";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Engrams – Persistent project memory for AI coding assistants. Your AI remembers decisions, patterns, and progress across every session."
    />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Engrams – Enhanced Memory & Knowledge Platform</title>
  </head>
  <body class="home-body">
    <!-- ── Header ── -->
    <header class="home-header">
      <div class="hdr-inner">
        <a href="/" class="logo">
          <span class="logo-mark"
            ><img
              src="/engram.png"
              alt=""
              class="logo-img"
              aria-hidden="true"
            /></span
          >
          <span class="logo-text">Engrams</span>
        </a>
        <nav class="hdr-nav">
          <a href="/docs/getting-started">Docs</a>
          <a
            href="https://github.com/stevebrownlee/engrams"
            target="_blank"
            rel="noopener">GitHub</a
          >
      </div>
    </header>

    <!-- ── Hero ── -->
    <section class="hero">
      <div class="hero-bg" aria-hidden="true">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
      </div>
      <div class="hero-content">
        <h1 class="hero-title">
          AI context memory that<br />
          <span class="gradient-text">actually works</span>
        </h1>
      </div>
    </section>

    <!-- ── Feature Cards ── -->
    <section class="features">
      <div class="features-inner">
        <div class="feature-grid">
          {
            [
              {
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"></path></svg>',
                title: "Structured Memory",
                desc: "Save architectural decisions (ADRs), system patterns, task progress, and product context.",
              },
              {
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>',
                title: "FTS5 Search",
                desc: "Blazing fast local full-text search in SQLite lets your AI retrieve relevant details instantly.",
              },
              {
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>',
                title: "Git-Sync Friendly",
                desc: "Export the database to clean markdown files for version control, and import them back on checkout.",
              },
              {
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>',
                title: "Zero Overhead",
                desc: "Written in Rust with no background daemons, servers, memory footprint, or external APIs.",
              },
              {
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>',
                title: "Knowledge Graph",
                desc: "Link decisions to patterns, progress to decisions, and features to custom configuration data.",
              },
              {
                icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="15" x2="23" y2="15"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="15" x2="4" y2="15"></line></svg>',
                title: "Agent-Native",
                desc: "Simple JSON inputs/outputs designed for direct terminal tool execution by AI coding assistants.",
              },
            ].map((f) => (
              <div class="feature-card">
                <div class="feature-card-header">
                  <span class="feature-icon" set:html={f.icon}></span>
                  <h3>{f.title}</h3>
                </div>
                <p>{f.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="hero" style="display:block; padding: 3rem 1.5rem;">
      <div class="hero-actions">
        <a href="/docs/getting-started" class="btn-primary">Get started →</a>
      </div>

      <div class="hero-code" style="margin: 0 auto;">
        <div class="code-bar">
          <span class="dot red"></span><span class="dot yellow"></span><span
            class="dot green"></span><span class="filename">terminal</span>
        </div>
        <pre><code>{`$ engrams --help
Usage: engrams [OPTIONS] <COMMAND>

Commands:
  init             Initialize the database schema
  migrate          Migrate the database schema to the latest version
  product-context  Manage the product context document
  active-context   Manage the active context document
  history          View history of context documents
  decision         Log and search architectural decisions
  progress         Track task execution and progress
  pattern          Log recurring system patterns and conventions
  custom           Store arbitrary configuration or key-value data
  link             Create knowledge-graph relations between items
  activity         Get a recent summary of all modifications
  report           Generate a structured report of project knowledge
  batch            Perform multiple operations in a single transaction
  export           Dump database to Markdown files for git sync
  import           Import Markdown files back into the database

$ engrams decision log \\
  --summary "Use PostgreSQL for primary database" \\
  --rationale "Need ACID guarantees and complex queries" \\
  --tags "db,arch"
Decision logged as ID 1.

$ engrams decision search "caching"
# Search results retrieved instantly via FTS5 index...`}</code></pre>
      </div>
    </section>
  </body>

  <!-- ── Supported Tools ── -->
  <section class="tools-section">
    <div class="tools-inner">
      <div class="hero-badge" style="margin: 0 auto;">Open Source · v{__APP_VERSION__}</div>
      <h2 class="section-heading">Works with your favourite AI tools</h2>
      <div class="tool-chips">
        {
          [
            "Cursor",
            "Claude Code",
            "Antigravity",
            "Zed",
            "Terminal agents (e.g. pi, omp, etc.)",
          ].map((t) => <span class="chip">{t}</span>)
        }
      </div>
    </div>
  </section>

  <footer class="home-footer">
    <span>© {new Date().getFullYear()} Engrams · Apache-2.0 License</span>
    <a
      href="https://github.com/stevebrownlee/engrams"
      target="_blank"
      rel="noopener">GitHub</a
    >
  </footer>
</html>

<style>
  /* ── Base ── */
  .home-body {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    margin: 0;
  }

  .logo img {
    height: calc(var(--header-height) - 20px);
    width: auto;
    display: block;
    object-fit: contain;
  }

  /* ── Header ── */
  .home-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    height: var(--header-height);
  }
  .hdr-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 1.5rem;
    gap: 2rem;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
  }
  .logo-mark {
    font-size: 1.4rem;
    color: var(--sky-aqua);
  }
  .logo-text {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .hdr-nav {
    display: flex;
    gap: 1.5rem;
    margin-left: auto;
  }
  .hdr-nav a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .hdr-nav a:hover {
    color: var(--color-link);
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    padding: calc(var(--header-height) + 2rem) 1.5rem 1rem;
    display: flex;
    justify-content: center;
    background: linear-gradient(160deg, #f0f8ff 0%, #faf8fd 50%, #fff5f8 100%);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
  }
  .blob-1 {
    width: 500px;
    height: 500px;
    background: var(--sky-aqua);
    top: -100px;
    left: -80px;
  }
  .blob-2 {
    width: 400px;
    height: 400px;
    background: var(--pastel-petal);
    top: 60px;
    right: -60px;
  }
  .blob-3 {
    width: 300px;
    height: 300px;
    background: var(--lavender);
    bottom: 0;
    left: 40%;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 780px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(86, 203, 249, 0.15);
    color: #2070a0;
    border: 1px solid rgba(86, 203, 249, 0.35);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.8rem;
    margin-bottom: 1.5rem;
    letter-spacing: 0.04em;
  }
  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }
  .gradient-text {
    background: linear-gradient(
      135deg,
      var(--sky-aqua),
      var(--maya-blue) 40%,
      var(--pastel-petal)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 580px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 2.5rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: linear-gradient(135deg, var(--sky-aqua), var(--maya-blue));
    color: #fff;
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    box-shadow: 0 4px 15px rgba(86, 203, 249, 0.4);
    transition:
      opacity 0.15s,
      transform 0.12s;
  }
  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-2px);
    text-decoration: none;
  }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    background: #fff;
    color: var(--color-text);
    font-weight: 600;
    font-size: 0.9375rem;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius-md);
    border: 1.5px solid var(--color-border);
    text-decoration: none;
    transition:
      border-color 0.15s,
      transform 0.12s;
  }
  .btn-secondary:hover {
    border-color: var(--maya-blue);
    transform: translateY(-2px);
    text-decoration: none;
  }

  /* Hero code block */
  .hero-code {
    width: 100%;
    max-width: 640px;
    background: #1a2035;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.06);
    text-align: left;
  }
  .code-bar {
    background: #141929;
    padding: 0.55rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot.red {
    background: #ff5f57;
  }
  .dot.yellow {
    background: #ffbd2e;
  }
  .dot.green {
    background: #28ca41;
  }
  .filename {
    font-size: 0.75rem;
    color: #6b7590;
    margin-left: 0.4rem;
    font-family: var(--font-mono);
  }
  .hero-code pre {
    background: transparent;
    margin: 0;
    padding: 1.25rem 1.5rem;
    font-size: 0.825rem;
    line-height: 1.65;
  }
  .hero-code pre code {
    color: #c9d3e8;
  }

  /* ── Features ── */
  .features {
    padding: 0.5rem 1.5rem 3rem 1.5rem;
    background: #fff;
  }
  .features-inner {
    max-width: 1050px;
    margin: 0 auto;
  }
  .section-heading {
    text-align: center;
    font-size: 1.875rem;
    font-weight: 700;
    margin-bottom: 2.5rem;
    color: var(--color-text);
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 1.25rem;
  }
  .feature-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    transition:
      box-shadow 0.2s,
      transform 0.2s;
  }
  .feature-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .feature-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.8rem;
  }
  .feature-icon {
    display: block;
    margin-bottom: 0;
  }
  .feature-icon svg {
    width: 24px;
    height: 24px;
    stroke: var(--color-link);
    display: block;
  }
  .feature-card h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
  }
  .feature-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Tools ── */
  .tools-section {
    padding: 4rem 1.5rem;
    background: var(--lavender);
  }
  .tools-inner {
    max-width: 860px;
    margin: 0 auto;
    text-align: center;
  }
  .tool-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    margin-top: 1.5rem;
  }
  .chip {
    background: #fff;
    border: 1.5px solid var(--powder-blue);
    border-radius: 999px;
    padding: 0.4rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text-muted);
    transition:
      border-color 0.15s,
      color 0.15s;
  }
  .chip:hover {
    border-color: var(--sky-aqua);
    color: var(--color-text);
  }

  /* ── CTA ── */
  .cta-section {
    padding: 5rem 1.5rem;
    background: linear-gradient(
      135deg,
      var(--sky-aqua) 0%,
      var(--maya-blue) 60%,
      var(--pastel-petal) 100%
    );
  }
  .cta-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }
  .cta-inner h2 {
    color: #fff;
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }
  .cta-inner p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }
  .cta-section .btn-primary {
    background: #fff;
    color: var(--color-text);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  /* ── Footer ── */
  .home-footer {
    background: #fff;
    border-top: 1px solid var(--color-border);
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .home-footer a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .home-footer a:hover {
    color: var(--color-link);
  }
</style>
