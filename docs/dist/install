#!/usr/bin/env bash
set -e

# engrams.sh install script
# Usage: curl -fsSL https://engrams.sh/install | bash

GITHUB_REPO="stevebrownlee/engrams-cli"

echo "Installing engrams CLI..."

# Detect OS and Architecture
OS="$(uname -s)"
ARCH="$(uname -m)"

case "$OS" in
    Linux)
        OS_TARGET="unknown-linux-musl"
        ;;
    Darwin)
        OS_TARGET="apple-darwin"
        ;;
    *)
        echo "Error: Unsupported OS '$OS'"
        exit 1
        ;;
esac

case "$ARCH" in
    x86_64|amd64)
        ARCH_TARGET="x86_64"
        ;;
    arm64|aarch64)
        ARCH_TARGET="aarch64"
        ;;
    *)
        echo "Error: Unsupported architecture '$ARCH'"
        exit 1
        ;;
esac

TARGET="${ARCH_TARGET}-${OS_TARGET}"

# Create local bin directory if it doesn't exist
BIN_DIR="$HOME/.local/bin"
mkdir -p "$BIN_DIR"

# Fetch latest release URL from GitHub API
echo "Fetching latest release..."
LATEST_URL=$(curl -fsSL https://api.github.com/repos/$GITHUB_REPO/releases/latest | grep "browser_download_url.*engrams-$TARGET.tar.gz" | cut -d : -f 2,3 | tr -d ' "')

if [ -z "$LATEST_URL" ]; then
    echo "Error: Could not find a release for $TARGET"
    echo "Please ensure binaries are published at https://github.com/$GITHUB_REPO/releases"
    exit 1
fi

echo "Downloading $LATEST_URL..."
TMP_DIR=$(mktemp -d)
curl -fsSL "$LATEST_URL" | tar -xz -C "$TMP_DIR"

# Install binary
mv "$TMP_DIR/engrams" "$BIN_DIR/engrams"
chmod +x "$BIN_DIR/engrams"
rm -rf "$TMP_DIR"

echo ""
echo "✅ engrams installed successfully to $BIN_DIR/engrams"

# Check if it's on PATH
if command -v engrams >/dev/null 2>&1; then
    echo "Ready to use! Try running: engrams help"
else
    echo ""
    echo "⚠️  Please add $BIN_DIR to your PATH to use the 'engrams' command."
    echo "You can do this by adding the following line to your ~/.bashrc or ~/.zshrc:"
    echo "  export PATH=\"\$HOME/.local/bin:\$PATH\""
fi
